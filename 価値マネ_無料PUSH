SELECT
  sh.kintone_code,
  ns.shop_id,
  MAX(ns.send_datetime) AS max_send_datetime,
  ns.created
FROM notifications ns
left join shops sh on ns.shop_id = sh.id
WHERE ns.area_id IS NULL and shop_id not in (0,11755) and send_datetime <= '2026-01-17 00:00:00'
GROUP BY ns.shop_id
ORDER BY `ns`.`shop_id` ASC;
